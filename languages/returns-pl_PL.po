msgstr "Nie znaleziono tego zamówienia lub nie masz uprawnień do jego zwrotu."

#: src/Service/ReturnRequestForm.php:172
msgid "This order is not eligible for a return."
msgstr "To zamówienie nie kwalifikuje się do zwrotu."

