#. Plugin Name of the plugin
#: returns.php
msgid "Returns - RMA and Return Requests for WooCommerce"
msgstr "Returns - RMA i zgłoszenia zwrotów dla WooCommerce"

#. Plugin URI of the plugin
#: returns.php
msgid "https://plogins.com/returns/"
msgstr "https://plogins.com/returns/"

#. Description of the plugin
#: returns.php
msgid "Let customers request returns/refunds from their account and manage RMAs in the admin."
msgstr "Pozwól klientom zgłaszać zwroty i reklamacje z poziomu konta oraz zarządzaj zgłoszeniami RMA w panelu administracyjnym."

#. Author of the plugin
#: returns.php
msgid "WPPoland"
msgstr "WPPoland"

#. Author URI of the plugin
#: returns.php
msgid "https://plogins.com/"
msgstr "https://plogins.com/"

#: returns.php:59
msgid "Returns - RMA and Return Requests for WooCommerce requires WooCommerce to be active."
msgstr "Wtyczka Returns - RMA i zgłoszenia zwrotów dla WooCommerce wymaga aktywnej wtyczki WooCommerce."

#: src/Admin/Settings.php:57
msgid "Returns — RMA settings"
msgstr "Returns — ustawienia RMA"

#: src/Admin/Settings.php:58
msgid "Returns"
msgstr "Zwroty"

#: src/Admin/Settings.php:96
msgid "Let customers request returns from their account"
msgstr "Pozwól klientom zgłaszać zwroty z poziomu konta"

#: src/Admin/Settings.php:98
msgid "Customers open a return from My Account → Orders: they pick items, a quantity, a reason and an optional note. Each request is emailed to you and saved as a private record you manage here, with a status the customer can follow."
msgstr "Klienci otwierają zwrot z poziomu Moje konto → Zamówienia: wybierają produkty, ilość, powód oraz opcjonalną notatkę. Każde zgłoszenie jest wysyłane do Ciebie e-mailem i zapisywane jako prywatny wpis, którym zarządzasz tutaj, wraz ze statusem, który klient może śledzić."

#: src/Admin/Settings.php:101
msgid "View return requests"
msgstr "Zobacz zgłoszenia zwrotów"

#: src/Admin/Settings.php:109
msgid "General"
msgstr "Ogólne"

#: src/Admin/Settings.php:113
msgid "Enable returns"
msgstr "Włącz zwroty"

#: src/Admin/Settings.php:119
msgid "Allow customers to request returns from My Account."
msgstr "Zezwól klientom na zgłaszanie zwrotów z poziomu Moje konto."

#: src/Admin/Settings.php:121
msgid "When off, the \"Request a return\" action and form are hidden everywhere on the storefront."
msgstr "Po wyłączeniu akcja „Zgłoś zwrot” oraz formularz są ukryte w całym sklepie."

#: src/Admin/Settings.php:125
#: src/Admin/Settings.php:128
msgid "Eligible order statuses"
msgstr "Statusy zamówień objęte zwrotem"

#: src/Admin/Settings.php:139
msgid "Only orders in these statuses can be returned."
msgstr "Tylko zamówienia w tych statusach mogą zostać zwrócone."

#: src/Admin/Settings.php:144
msgid "Return window (days)"
msgstr "Okno zwrotu (dni)"

#: src/Admin/Settings.php:150
msgid "How many days after the order date a return may be requested. 0 = no time limit."
msgstr "Ile dni po dacie zamówienia można zgłosić zwrot. 0 = brak limitu czasu."

#: src/Admin/Settings.php:179
msgid "Processing"
msgstr "W trakcie realizacji"

#: src/Admin/Settings.php:180
#: src/Support/Statuses.php:32
msgid "Completed"
msgstr "Zakończone"

